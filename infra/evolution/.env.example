# Copie este arquivo para .env e preencha os valores

# URL pública da sua Evolution API (sem barra final)
# Ex: https://evo.seudominio.com  ou  http://123.45.67.89:8080
EVOLUTION_SERVER_URL=https://evo.seudominio.com

# Chave de autenticação global — crie uma senha forte
# Você vai usar essa mesma chave ao conectar no NXT Hub
EVOLUTION_API_KEY=troque-por-uma-chave-forte-aqui

# URL do webhook do NXT Hub — substitua pelo domínio do seu app
NXT_WEBHOOK_URL=https://seuapp.com/api/webhooks/messaging/whatsapp_evolution
